{
  "permissions": {
    "allow": [
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm install)",
      "Bash(npm install *)",
      "Bash(ls *)",
      "Bash(find src *)",
      "Bash(grep *)"
    ],
    "deny": [
      "Bash(git push *)",
      "Bash(rm -rf *)",
      "Bash(git reset --hard *)"
    ]
  }
}
